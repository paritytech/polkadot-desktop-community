{
  "name": "polkadot-desktop",
  "description": "Polkadot Enterprise application",
  "type": "module",
  "version": "0.1.0",
  "main": "./release/build/main.cjs",
  "repository": "https://github.com/paritytech/polkadot-desktop-community",
  "license": "GPL-3.0-only",
  "private": true,
  "author": {
    "name": "Polkadot Desktop contributors"
  },
  "scripts": {
    "config": "config/bin.js",
    "electron": "electron .",
    "preview": "cross-env RENDERER_SOURCE=localhost npm run build:staging && concurrently \"npm run renderer:preview\" \"npm run electron\"",
    "start": "npm run r clean:build main:dev preload:dev && concurrently \"npm run main:dev:watch\" \"npm run preload:dev:watch\" \"npm run renderer:dev:watch\" \"wait-on tcp:4000 && npm run electron\"",
    "start:web": "npm run renderer:dev:watch",
    "renderer:dev": "cross-env LOGGER=false vite build --mode development --logLevel warn -c vite.config.renderer.ts",
    "renderer:dev:watch": "cross-env LOGGER=false vite --mode development --logLevel warn -c vite.config.renderer.ts",
    "renderer:staging": "vite build --mode staging --logLevel warn -c vite.config.renderer.ts",
    "renderer:prod": "vite build --mode production --logLevel warn -c vite.config.renderer.ts",
    "renderer:preview": "vite preview --mode staging --port $(node config/bin.js renderer.server.port) -c vite.config.renderer.ts",
    "preload:dev": "vite build --mode development --logLevel warn -c vite.config.preload.ts",
    "preload:dev:watch": "vite build --mode development --logLevel warn -c vite.config.preload.ts --watch",
    "preload:staging": "vite build --mode staging --logLevel warn -c vite.config.preload.ts",
    "preload:prod": "vite build --mode production --logLevel warn -c vite.config.preload.ts",
    "main:dev": "vite build --mode development --logLevel warn -c vite.config.main.ts",
    "main:dev:watch": "vite build --mode development --logLevel warn -c vite.config.main.ts --watch",
    "main:dev:watch:electron": "concurrently \"npm run main:dev:watch\" \"npm run preload:dev:watch\" \"npm run electron\"",
    "main:staging": "vite build --mode staging --logLevel warn -c vite.config.main.ts",
    "main:prod": "vite build --logLevel warn -c vite.config.main.ts",
    "build": "npm run r clean:prod main:prod preload:prod renderer:prod",
    "build:dev": "npm run r clean:prod clean:build main:dev preload:dev renderer:dev",
    "build:e2e": "cross-env RENDERER_SOURCE=filesystem npm run r clean:prod clean:build main:dev preload:dev renderer:dev",
    "build:staging": "npm run r clean:prod clean:build main:staging preload:staging renderer:staging",
    "postbuild": "node scripts/postbuild.js",
    "postbuild:staging": "node scripts/postbuild.js staging",
    "papi:generate": "papi",
    "papi:update": "papi update",
    "dist": "cross-env NODE_ENV=production ./node_modules/.bin/electron-builder --config electron-builder.js -p never",
    "dist:staging": "cross-env NODE_ENV=staging ./node_modules/.bin/electron-builder --config electron-builder.js -p never",
    "clean:build": "rimraf release/build",
    "clean:prod": "rimraf release/dist",
    "staging:sequence": "npm run r clean:build clean:prod build:staging postbuild:staging dist:staging",
    "prod:sequence": "npm run r clean:build clean:prod build postbuild dist",
    "test": "vitest run && vitest run --passWithNoTests -c vitest.main.config.ts",
    "test:main": "vitest run --passWithNoTests -c vitest.main.config.ts",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage-new-files": "vitest run --coverage --changed dev",
    "test:e2e:gen": "npx bddgen",
    "test:e2e": "npx bddgen && playwright test --project=smoke",
    "test:e2e:smoke": "npx bddgen && playwright test --project=smoke",
    "test:e2e:auth": "npx bddgen && playwright test --project=auth",
    "test:e2e:authenticated": "npx bddgen && playwright test --project=authenticated",
    "test:e2e:all": "npx bddgen && playwright test --project=smoke --project=auth --project=authenticated --project=product-sdk --project=chat",
    "test:e2e:product-sdk": "npx bddgen && playwright test --project=product-sdk",
    "test:e2e:chat": "npx bddgen && playwright test --project=chat",
    "test:e2e:link-navigation": "npx bddgen && playwright test --project=link-navigation",
    "test:e2e:security": "playwright test --project=security",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:record": "PWDEBUG=1 npx tsx e2e/tests/record.e2e.ts",
    "test:e2e:report": "playwright show-report",
    "knip": "knip",
    "arch:metrics": "depcruise src --output-type metrics",
    "arch:metrics:folders": "depcruise src --output-type metrics | awk 'NR<=2 || $1==\"folder\"'",
    "arch:churn": "git log --since=\"6 months ago\" --format= --name-only -- src ':!src/**/locales/**' | grep . | sort | uniq -c | sort -rn | head -40",
    "types": "tsc -p tsconfig.json --noEmit",
    "types:watch": "tsc -p tsconfig.json --noEmit --watch",
    "types:files": "tsc-files --noEmit",
    "fmt:generic": "prettier",
    "fmt:check": "prettier \"./src/**/*.{ts,tsx}\" \"./main/**/*.ts\" --check --log-level warn",
    "fmt:fix": "prettier \"./src/**/*.{ts,tsx}\" \"./main/**/*.ts\" --write --log-level warn",
    "lint:generic": "eslint --cache --cache-location ./node_modules/.cache/eslint --rule 'prettier/prettier: off'",
    "lint": "npm run lint:generic ./src ./main",
    "lint:fix": "npm run lint:generic -- ./src ./main --fix && npm run fmt:fix",
    "lint:tests": "npm run lint:generic -- e2e \"**/*.{test,spec}.{ts,tsx}\"",
    "lint:tests:fix": "npm run lint:generic -- e2e \"**/*.{test,spec}.{ts,tsx}\" --fix",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o $(npm run --silent run config folders.storybookBuild)",
    "githook:pre-commit": "lint-staged --relative",
    "prepare": "husky",
    "run-s": "npm-run-all",
    "r": "npm run run-s"
  },
  "engines": {
    "node": ">=24.x",
    "npm": ">=10.x"
  },
