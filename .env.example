# Copy to `.env` and fill in what you need. Everything is optional unless noted —
# features whose variables are empty stay disabled. See docs/PUBLISHING.md for the
# full build/sign/publish guide.

# ───────────────────────────── Firebase Remote Config ─────────────────────────────
# Public client identifiers (the apiKey is NOT a secret); only API_KEY / PROJECT_ID /
# APP_ID are required by Remote Config. The rest are kept for future Firebase services.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=<NAME>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<NAME>
VITE_FIREBASE_STORAGE_BUCKET=<NAME>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ───────────────────────────── Environment catalog ────────────────────────────────
# JSON describing every environment-specific value the app needs that Remote Config
# does NOT serve. Channels inherit the `shared` block; each channel key (e.g. `alpha`)
# is the id, `name` is the display label in the picker; `roles` reference `chains_v2`
# entry ids; `default` must be a channel key. Values below are placeholders — replace
# with your real channels.
VITE_ENVIRONMENTS={"default":"alpha","shared":{"botNetwork":"example-net","hostChatNetwork":"example-net","iosBundleId":"com.example.app","digitalDollarAsset":{"assetId":1,"symbol":"tUSD","precision":6,"palletName":"Assets"}},"channels":{"alpha":{"name":"Alpha Testnet","roles":{"people":"alpha-people","bulletin":"alpha-bulletin","assetHub":"alpha-asset-hub"}},"beta":{"name":"Beta Testnet","roles":{"people":"beta-people","bulletin":"beta-bulletin","assetHub":"beta-asset-hub"}}}}

# ───────────────────────────── Device-sync TURN relay ─────────────────────────────
# WebRTC TURN credentials for device-sync (optional; STUN-only fallback works on most
# NATs). Point these at your own TURN relay.
VITE_WEBRTC_TURN_HOST=
VITE_WEBRTC_TURN_SECRET=
VITE_WEBRTC_TURN_TTL=

# ───────────────────────────── Sandbox network policy ────────────────────────────
# Comma-separated list of TURN/STUN hostnames that product webviews may reach
# WITHOUT triggering the per-product remote-permission prompt. Empty = no
# auto-allowed relays, so every TURN/STUN request goes through the user-facing
# permission flow (fail-closed default — safe for forks without a dedicated
# relay). Set this only when you operate a known relay that products should
# reach silently. Exact host or any subdomain (e.g. `relay.example.com` matches
# `sub.relay.example.com`). Independent of `VITE_WEBRTC_TURN_HOST` above —
# that's the desktop's own device-sync relay; this is what sandboxed products
# may dial.
SANDBOX_RELAY_ALLOWLIST=

# Comma-separated list of IPFS gateway hostnames that product webviews may
# reach (GET only) WITHOUT triggering the per-product remote-permission
# prompt. Empty = no auto-allowed gateways, so every IPFS request goes through
# the user-facing permission flow (fail-closed default — safe for forks
# without a dedicated gateway). Exact host or any subdomain (e.g.
# `ipfs.example.com` matches `cdn.ipfs.example.com`).
SANDBOX_IPFS_ALLOWLIST=

# ───────────────────────────── Error reporting ────────────────────────────────────
# Sentry DSN baked in at build time. Empty = crash reporting disabled.
SENTRY_DSN=

# ───────────────────────────── Auto-update ────────────────────────────────────────
# Generic electron-updater feed URL baked in at build time. Empty = auto-update
# disabled. BUILD_SOURCE tells the updater how the build is distributed: `github`
# (GitHub Releases) or `s3` (generic static file server behind AUTO_UPDATE_URL).
AUTO_UPDATE_URL=https://updates.example.com/desktop
BUILD_SOURCE=

# ───────────────────────────── Build / dev toggles ────────────────────────────────
# Verbose logger output in main/preload/renderer. Any non-empty value enables it.
LOGGER=
# Where the Electron main process loads the renderer from: `localhost` (dev server)
# or `filesystem` (built assets). Build scripts set this for you; override only for
# unusual local setups.
RENDERER_SOURCE=
# Override Electron's userData directory (used by e2e to isolate test profiles).
ELECTRON_USER_DATA=

# ───────────────────────────── E2E tests ──────────────────────────────────────────
# Base URL and API token of the signing-bot service. Required for auth /
# authenticated / chat / product-sdk projects; smoke, security and link-navigation
# run without them.
BOT_URL=https://signing-bot.example.com
BOT_TOKEN=
# Pin bot identities instead of generating per-run ones (optional).
BOT_USERNAME=
# Pre-attested {alice, bob} pairs for chat tests (default 6).
CHAT_PAIR_POOL_SIZE=
# Serve link-navigation fixtures from an external URL instead of the local server.
LINK_TESTS_URL=

# ───────────────────────────── Maintenance scripts ────────────────────────────────
# scripts/rewrite-update-metadata.js — directory with packaged artifacts (default:
# artifacts).
ARTIFACTS_DIR=
